# Telegram bot token (required for verify_admin + posting)
TELEGRAM_BOT_TOKEN=

# AI provider keys (set at least one)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional: Gemini Imagen image generation
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# GEMINI_IMAGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional: OpenAI Images
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1/images/generations

# Redis (Celery broker/result backend)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
